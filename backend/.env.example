# Required
MONGO_URI=mongodb://127.0.0.1:27017/expense-tracker
JWT_SECRET=change_me
SESSION_SECRET=change_me

# Optional (CORS / redirects)
FRONTEND_URL=http://127.0.0.1:5500
CORS_ORIGIN=http://127.0.0.1:5500
BACKEND_PUBLIC_URL=http://localhost:5000

# Optional (Auth emails / password reset)
# If PASSWORD_RESET_URL_BASE is blank, FRONTEND_URL will be used.
AUTH_FROM_EMAIL=
PASSWORD_RESET_URL_BASE=
# Between 5 and 1440 minutes
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Optional (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional (Suggestions -> Email)
# Recommended: use an SMTP provider (or a Gmail App Password).
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_app_password_here
# SUGGESTIONS_TO_EMAIL=yourgmail@gmail.com
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SUGGESTIONS_TO_EMAIL=
SUGGESTIONS_FROM_EMAIL=

# Optional (Profile images)
# PROFILE_IMAGE_STORAGE=s3  # auto | firebase | s3 (local uploads disabled)
PROFILE_IMAGE_STORAGE=s3

# Optional (AWS S3)
# If running on AWS (EC2/ECS/Lambda), you can omit keys and use IAM roles instead.
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional (Firebase Storage)
FIREBASE_STORAGE_BUCKET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY should include literal "\n" sequences for newlines
FIREBASE_PRIVATE_KEY=
